    "eligibility_criteria": [
        {
            "id": "crit_retail_business",
            "type": "must",
            "field": "business_type",
            "operator": "equals",
            "value": "retail",
            "description": "Applicant operates a retail business"
        },
        {
            "id": "crit_la_city_known",
            "type": "must",
            "field": "location.city",
            "operator": "exists",
            "value": true,
            "description": "Business city is provided"
        },
        {
            "id": "crit_equipment_or_inventory",
            "type": "preferred",
            "field": "urgent_needs",
            "operator": "contains",
            "value": "equipment",
            "description": "Applicant needs equipment or inventory support"
        }
    ],
    "documents_needed": [
        "doc_business_license",
        "doc_vendor_quote",
        "doc_income_proof"
    ],
